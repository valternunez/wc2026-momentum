# --- Raw & interim scraped data (derived-data-only publishing policy) ---
# We commit ONLY data/processed/ and snapshots/. Raw scraped JSON stays local
# (ToS-respecting) but is the reproducibility source on the scraping machine.
data/raw/
data/interim/

# Keep the processed table and snapshots tracked (negate the dir ignores below
# would over-broaden, so we explicitly do NOT ignore those folders).

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
.marimo/

# --- Build / site output (regenerated by CI; safe to ignore locally) ---
site/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Secrets ---
.env
*.local

# --- Design source assets (kept local, not part of the repo) ---
*.zip
WC2026 Momentum Editorial Design/
